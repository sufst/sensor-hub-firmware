{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {}
        },
        {
            "name": "Debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "default-Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SENSOR_HUB_CONFIG": "default"
            }
        },
        {
            "name": "pedalbox-Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SENSOR_HUB_CONFIG": "pedalbox"
            }
        },
        {
            "name": "pedalbox-Debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SENSOR_HUB_CONFIG": "pedalbox"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        },
        {
            "name": "default-Release",
            "configurePreset": "default-Release"
        },
        {
            "name": "pedalbox-Release",
            "configurePreset": "pedalbox-Release"
        },
        {
            "name": "pedalbox-Debug",
            "configurePreset": "pedalbox-Debug"
        }
    ]
}
